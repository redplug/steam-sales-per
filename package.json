{
  "name": "steam-sales-per",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Filter official Steam client Store sale cards by discount percent.",
  "bin": "dist/steam-sales-per.cjs",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "probe": "tsx scripts/probe-steam-cdp.ts",
    "probe:75": "tsx scripts/probe-steam-cdp.ts --threshold 75",
    "watch": "tsx scripts/probe-steam-cdp.ts --watch",
    "watch:75": "tsx scripts/probe-steam-cdp.ts --threshold 75 --watch",
    "ui": "tsx scripts/control-panel.ts",
    "build": "esbuild scripts/control-panel.ts --bundle --platform=node --format=cjs --outfile=dist/steam-sales-per.cjs --banner:js=\"#!/usr/bin/env node\"",
    "build:exe": "npm run build && pkg dist/steam-sales-per.cjs --targets node20-win-x64 --output dist/steam-sales-per.exe"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.12",
    "@yao-pkg/pkg": "^6.5.1",
    "esbuild": "^0.25.12",
    "linkedom": "^0.18.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "pkg": {
    "scripts": [],
    "assets": []
  }
}
